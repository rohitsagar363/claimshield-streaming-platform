{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "claim.status_updated.v1",
  "title": "claim.status_updated.v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "claim_id": {
      "type": "string"
    },
    "old_status": {
      "type": "string",
      "enum": [
        "submitted",
        "pending_review",
        "approved",
        "denied",
        "paid"
      ]
    },
    "new_status": {
      "type": "string",
      "enum": [
        "submitted",
        "pending_review",
        "approved",
        "denied",
        "paid"
      ]
    },
    "reason": {
      "type": "string"
    },
    "event_time": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "claim_id",
    "old_status",
    "new_status",
    "reason",
    "event_time"
  ]
}
